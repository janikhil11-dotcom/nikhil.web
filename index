    <title>Nikhil KJ — Front-end Developer</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --orange: #E84E1B;
            --orange-dark: #c43d12;
            --cream: #F2F0EC;
            --dark: #1a1a18;
            --mid: #888880;
            --font: 'Outfit', sans-serif;
        }

        html { scroll-behavior: smooth; }

        body {
            background: var(--orange);
            font-family: var(--font);
            overflow-x: hidden;
            cursor: none;
        }

        /* Custom cursor */
        .cursor {
            width: 12px; height: 12px;
            background: var(--orange);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 99999;
            transition: transform 0.15s ease, background 0.15s ease;
            transform: translate(-50%, -50%);
        }
        .cursor-follower {
            width: 36px; height: 36px;
            border: 1.5px solid var(--orange);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 99998;
            transition: transform 0.4s ease, border-color 0.15s ease;
            transform: translate(-50%, -50%);
        }

        /* ===== NAVBAR ===== */
        nav {
            position: fixed; top: 0; left: 0; right: 0;
            z-index: 1000;
            display: flex; align-items: center; justify-content: space-between;
            padding: 1.4rem 3rem;
            mix-blend-mode: normal;
        }
        .nav-inner {
            display: flex; align-items: center; justify-content: space-between;
            width: 100%;
            background: var(--cream);
            border-radius: 50px;
            padding: 0.8rem 1.8rem;
        }
        .logo {
            font-size: 1.1rem; font-weight: 800; letter-spacing: 0.05em;
            color: var(--dark); text-decoration: none;
        }
        .logo span { color: var(--orange); }
        .nav-links { display: flex; gap: 2.5rem; list-style: none; }
        .nav-links a {
            font-size: 0.78rem; font-weight: 600; letter-spacing: 0.12em;
            text-transform: uppercase; color: var(--dark);
            text-decoration: none; transition: color 0.2s;
        }
        .nav-links a:hover { color: var(--orange); }

        /* ===== HERO ===== */
        .hero {
            min-height: 100vh;
            background: var(--orange);
            display: flex; align-items: stretch;
            padding-top: 90px;
        }
        .hero-inner {
            background: var(--cream);
            margin: 0 2rem 2rem;
            border-radius: 24px;
            flex: 1;
            display: flex; flex-direction: column;
            padding: 3rem 3.5rem;
            overflow: hidden;
            position: relative;
            min-height: calc(100vh - 90px);
        }
        .hero-top {
            display: flex; justify-content: space-between; align-items: flex-start;
        }
        .hero-tag {
            font-size: 0.75rem; font-weight: 600; letter-spacing: 0.18em;
            text-transform: uppercase; color: var(--mid);
        }
        .hero-nav-hint {
            font-size: 0.75rem; color: var(--mid); letter-spacing: 0.05em;
        }
        .hero-headline {
            font-size: clamp(5rem, 12vw, 10rem);
            font-weight: 900; line-height: 0.9;
            color: var(--dark); letter-spacing: -0.03em;
            margin: 1.5rem 0;
        }
        .hero-headline .line2 {
            padding-left: 8%;
            display: block;
        }
        .hero-headline .line3 {
            padding-left: 20%;
            display: block;
        }

        /* Text mask effect on headline */
        .hero-headline .masked {
            background-image: url('https://images.unsplash.com/photo-1419242902214-272b3f66ee7a?w=1200&q=80');
            background-size: cover;
            background-position: center;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-bottom {
            display: flex; justify-content: space-between; align-items: flex-end; margin-top: auto;
        }
        .hero-desc {
            font-size: 0.9rem; color: #666; line-height: 1.7;
            max-width: 220px;
        }
        .hero-cta {
            width: 130px; height: 130px;
            background: var(--orange);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            text-decoration: none;
            flex-shrink: 0;
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease;
        }
        .hero-cta:hover { transform: scale(1.08); }
        .hero-cta-text {
            font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em;
            text-transform: uppercase; color: var(--cream);
            text-align: center; line-height: 1.5;
        }
        .hero-social {
            font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em;
            text-transform: uppercase; color: var(--mid);
            display: flex; gap: 1.5rem;
        }
        .hero-social a { color: var(--mid); text-decoration: none; transition: color 0.2s; }
        .hero-social a:hover { color: var(--dark); }

        /* ===== SECTION SHARED ===== */
        section { background: var(--orange); }
        .section-inner {
            background: var(--cream);
            margin: 0 2rem;
            border-radius: 24px;
            padding: 4rem 3.5rem;
            margin-bottom: 2rem;
        }
        .section-label {
            font-size: 0.7rem; font-weight: 700; letter-spacing: 0.2em;
            text-transform: uppercase; color: var(--mid);
            margin-bottom: 1rem;
        }
        .section-title {
            font-size: clamp(2rem, 4vw, 3.2rem);
            font-weight: 800; color: var(--dark);
            line-height: 1.1; letter-spacing: -0.02em;
        }

        /* ===== WHAT I DO (Services) ===== */
        .services-header {
            display: flex; justify-content: space-between; align-items: flex-start;
            margin-bottom: 3rem;
        }
        .services-desc {
            font-size: 0.9rem; color: #666; max-width: 300px; line-height: 1.7;
        }
        .view-all {
            display: inline-flex; align-items: center; gap: 0.5rem;
            background: var(--orange); color: var(--cream);
            border-radius: 50px; padding: 0.5rem 1.2rem;
            font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em;
            text-transform: uppercase; text-decoration: none;
            transition: background 0.2s;
        }
        .view-all:hover { background: var(--orange-dark); }
        .view-all .arrow {
            width: 18px; height: 18px; border-radius: 50%;
            background: rgba(255,255,255,0.25);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.7rem;
        }

        .services-grid {
            display: grid; grid-template-columns: repeat(3, 1fr);
            gap: 0; border-top: 1px solid #ddd;
        }
        .service-item {
            padding: 2rem 0; border-bottom: 1px solid #ddd;
            border-right: 1px solid #ddd;
        }
        .service-item:nth-child(3n) { border-right: none; padding-right: 0; }
        .service-item:nth-child(1), .service-item:nth-child(2), .service-item:nth-child(3) {
            /* first row — no extra top */
        }
        .service-item { padding: 2rem 1.5rem; }
        .service-item:nth-child(3n+1) { padding-left: 0; }
        .service-item:nth-child(3n) { padding-right: 0; border-right: none; }

        .service-num {
            font-size: 0.65rem; font-weight: 700; letter-spacing: 0.15em;
            color: var(--mid); margin-bottom: 1.2rem;
        }
        .service-name {
            font-size: 1.1rem; font-weight: 700; color: var(--dark);
            margin-bottom: 0.8rem; line-height: 1.2;
        }
        .service-name.accent { color: var(--orange); }
        .service-tags {
            display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem;
        }
        .service-tag {
            font-size: 0.68rem; color: #777; letter-spacing: 0.05em;
        }
        .service-desc {
            font-size: 0.82rem; color: #666; line-height: 1.6;
        }
        .service-link {
            display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1rem;
            font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em;
            text-transform: uppercase; color: var(--dark); text-decoration: none;
            background: rgba(232,78,27,0.1); padding: 0.35rem 0.9rem;
            border-radius: 50px; transition: background 0.2s, color 0.2s;
        }
        .service-link:hover { background: var(--orange); color: var(--cream); }

        /* ===== PROJECTS ===== */
        .projects-header {
            display: flex; justify-content: space-between; align-items: flex-start;
            margin-bottom: 3rem;
        }
        .project-row {
            display: grid; grid-template-columns: 1fr 1fr 2fr 1fr;
            align-items: center;
            padding: 1.5rem 0;
            border-top: 1px solid #ddd;
            gap: 1rem;
            transition: background 0.2s;
            border-radius: 8px;
            cursor: pointer;
        }
        .project-row:last-child { border-bottom: 1px solid #ddd; }
        .project-row:hover { background: rgba(232,78,27,0.05); padding-left: 0.5rem; }
        .project-row:hover .project-img-reveal { opacity: 1; }

        .project-num { font-size: 0.7rem; color: var(--mid); letter-spacing: 0.1em; }
        .project-cat {
            font-size: 0.68rem; font-weight: 600; letter-spacing: 0.12em;
            text-transform: uppercase; color: var(--mid);
        }
        .project-name {
            font-size: 1.3rem; font-weight: 800; color: var(--dark);
            letter-spacing: -0.01em;
        }
        .project-tech {
            font-size: 0.72rem; color: var(--mid);
        }
        .project-link-btn {
            display: inline-flex; align-items: center; gap: 0.4rem;
            font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em;
            text-transform: uppercase;
            background: var(--orange); color: var(--cream);
            padding: 0.5rem 1rem; border-radius: 50px;
            text-decoration: none; transition: background 0.2s;
            justify-self: end;
        }
        .project-link-btn:hover { background: var(--orange-dark); }

        /* ===== SKILLS ===== */
        .skills-grid {
            display: grid; grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem; margin-top: 2.5rem;
        }
        .skill-card {
            background: white; border-radius: 16px;
            padding: 1.8rem; border: 1px solid #eee;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .skill-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        }
        .skill-icon { font-size: 1.8rem; margin-bottom: 1rem; }
        .skill-name {
            font-size: 1rem; font-weight: 700; color: var(--dark);
            margin-bottom: 0.5rem;
        }
        .skill-desc { font-size: 0.82rem; color: #666; line-height: 1.6; }

        /* ===== CONTACT (dark) ===== */
        .contact-inner {
            background: var(--dark);
            margin: 0 2rem 2rem;
            border-radius: 24px;
            padding: 4rem 3.5rem;
        }
        .contact-label {
            font-size: 0.7rem; font-weight: 700; letter-spacing: 0.2em;
            text-transform: uppercase; color: #666;
            margin-bottom: 1rem;
        }
        .contact-title {
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 800; color: var(--cream);
            line-height: 1.1; letter-spacing: -0.02em;
            margin-bottom: 3rem;
        }
        .contact-form {
            display: grid; grid-template-columns: 1fr 1fr; gap: 0 3rem;
        }
        .form-field {
            padding: 1rem 0;
            border-bottom: 1px solid #333;
            margin-bottom: 0.5rem;
        }
        .form-field label {
            display: block; font-size: 0.68rem; font-weight: 600;
            letter-spacing: 0.12em; text-transform: uppercase;
            color: #555; margin-bottom: 0.5rem;
        }
        .form-field input, .form-field textarea {
            width: 100%; background: transparent;
            border: none; outline: none;
            font-size: 0.95rem; color: var(--cream);
            font-family: var(--font);
            resize: none;
        }
        .form-field input::placeholder, .form-field textarea::placeholder { color: #444; }
        .form-field.full { grid-column: 1/-1; }
        .form-field textarea { height: 60px; }

        .contact-footer {
            display: flex; justify-content: space-between; align-items: center;
            margin-top: 3rem; padding-top: 2rem;
            border-top: 1px solid #222;
        }
        .contact-social { display: flex; gap: 2rem; }
        .contact-social a {
            font-size: 0.68rem; font-weight: 700; letter-spacing: 0.15em;
            text-transform: uppercase; color: #555; text-decoration: none;
            transition: color 0.2s;
        }
        .contact-social a:hover { color: var(--orange); }
        .submit-btn {
            background: var(--orange); color: var(--cream);
            border: none; padding: 0.9rem 2rem;
            border-radius: 50px; font-size: 0.78rem;
            font-weight: 700; letter-spacing: 0.12em;
            text-transform: uppercase; cursor: none;
            transition: background 0.2s; font-family: var(--font);
        }
        .submit-btn:hover { background: var(--orange-dark); }

        .site-footer {
            background: var(--dark);
            padding: 1.5rem 5rem;
            display: flex; justify-content: space-between; align-items: center;
            border-top: 1px solid #1f1f1f;
            margin: 0 2rem 2rem;
            border-radius: 0 0 24px 24px;
            margin-top: -2rem;
        }
        .site-footer p {
            font-size: 0.72rem; color: #444; letter-spacing: 0.05em;
        }
        .site-footer a {
            font-size: 0.72rem; color: #444; text-decoration: none;
            transition: color 0.2s;
        }
        .site-footer a:hover { color: var(--orange); }

        /* ===== SCROLL ANIMATIONS ===== */
        .reveal {
            opacity: 0; transform: translateY(40px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }
        .reveal.visible {
            opacity: 1; transform: translateY(0);
        }
        .reveal-delay-1 { transition-delay: 0.1s; }
        .reveal-delay-2 { transition-delay: 0.2s; }
        .reveal-delay-3 { transition-delay: 0.3s; }
        .reveal-delay-4 { transition-delay: 0.4s; }
        .reveal-delay-5 { transition-delay: 0.5s; }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 900px) {
            nav { padding: 1rem 1rem; }
            .nav-inner { padding: 0.6rem 1.2rem; }
            .nav-links { gap: 1.2rem; }
            .hero-inner, .section-inner, .contact-inner { margin: 0 1rem; padding: 2.5rem 1.8rem; }
            .site-footer { margin: 0 1rem 1rem; padding: 1.2rem 1.8rem; }
            .hero-headline { font-size: clamp(3.5rem, 10vw, 6rem); }
            .services-grid { grid-template-columns: 1fr 1fr; }
            .skills-grid { grid-template-columns: 1fr 1fr; }
            .contact-form { grid-template-columns: 1fr; gap: 0; }
            .project-row { grid-template-columns: auto 1fr auto; }
            .project-cat { display: none; }
        }
        @media (max-width: 600px) {
            .nav-links { display: none; }
            .hero-headline { font-size: 3.5rem; }
            .hero-headline .line2 { padding-left: 5%; }
            .hero-headline .line3 { padding-left: 10%; }
            .services-grid { grid-template-columns: 1fr; }
            .skills-grid { grid-template-columns: 1fr; }
            .hero-cta { width: 100px; height: 100px; }
            .service-item { border-right: none !important; padding-left: 0 !important; }
        }
    </style>
</head>
